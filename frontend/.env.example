# Frontend environment variables (Vite).
# Copy to `.env` for local overrides, or set these in the Vercel dashboard.
#
# Base URL of the backend API.
#   - Local dev: leave UNSET. The Vite dev server proxies /api to the FastAPI
#     backend on http://127.0.0.1:8000, so requests stay same-origin.
#   - Production (Vercel): set to the deployed backend origin, no trailing slash.
#     Example: https://polytrade-api.onrender.com
# VITE_API_BASE_URL=https://your-backend.example.com
